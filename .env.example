# ─────────────────────────────────────────────────────────────
#  go_infra_link — Environment Configuration
#  Copy this file:  cp .env.example .env
#  Then adjust values below to your needs.
# ─────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────
APP_ENV=development            # development | production
APP_LOG_LEVEL=debug            # debug | info | warn | error

# ── Backend Server ───────────────────────────────────────────
BACKEND_PORT=8080              # backend API port
HTTP_ADDR=:8080                # backend bind address (keep in sync with BACKEND_PORT)
SWAGGER_ENABLED=true           # disable in production unless intentionally exposed

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=5173             # host port for SvelteKit dev server
FRONTEND_INTERNAL_PORT=5173    # container/internal frontend dev port

# ── Database (Postgres via Docker) ───────────────────────────
DB_DRIVER=postgres             # sqlite | postgres | mysql
POSTGRES_HOST=localhost        # backend host when running outside Docker
POSTGRES_SERVICE_HOST=postgres # backend host when running inside Docker network
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=go_infra_link
POSTGRES_PORT=5432             # host port for Postgres
POSTGRES_CONTAINER_PORT=5432   # container/internal Postgres port
DATABASE_URL=host=localhost user=postgres password=postgres dbname=go_infra_link port=5432 sslmode=disable

# ── pgAdmin ──────────────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_SERVER_NAME=go_infra_link

# ── Database Tuning ──────────────────────────────────────────
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h
DB_CONNECT_TIMEOUT=5s

# ── Auth / JWT ───────────────────────────────────────────────
JWT_SECRET=super-long-secret-change-me-in-production
ACCESS_TOKEN_TTL=8h
REFRESH_TOKEN_TTL=720h

# ── Cookies ──────────────────────────────────────────────────
COOKIE_SECURE=false            # true in production (HTTPS)
COOKIE_DOMAIN=                 # e.g. .example.com

# ── Seed User (create once if missing; existing users are not modified) ──
SEED_USER_ENABLED=true
SEED_USER_FIRST_NAME=Besart
SEED_USER_LAST_NAME=Morina
SEED_USER_EMAIL=besart_morina@hotmail.com
SEED_USER_PASSWORD=password

