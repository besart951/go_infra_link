# ─────────────────────────────────────────────────────────────
#  go_infra_link — PRODUCTION Environment Template
#  Copy:  cp .env.prod.example .env
#  Then fill in every value marked CHANGE_ME before deploying.
# ─────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────
APP_ENV=production
APP_LOG_LEVEL=info             # debug | info | warn | error

# ── Backend Server ───────────────────────────────────────────
BACKEND_PORT=8080
HTTP_ADDR=:8080
SWAGGER_ENABLED=false          # never expose Swagger in production
TRUSTED_PROXIES=               # set to your reverse proxy IP/CIDR, e.g. 172.18.0.0/16

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=80               # host port Caddy SPA listens on (80 or behind reverse proxy)

# ── Database ─────────────────────────────────────────────────
DB_DRIVER=postgres
POSTGRES_SERVICE_HOST=postgres # service name in Docker Compose network
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME    # use a strong random password
POSTGRES_DB=go_infra_link
POSTGRES_CONTAINER_PORT=5432
# Must match POSTGRES_SERVICE_HOST / USER / PASSWORD / DB above
DATABASE_URL=host=postgres user=CHANGE_ME password=CHANGE_ME dbname=go_infra_link port=5432 sslmode=disable

# ── Database Tuning ──────────────────────────────────────────
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h
DB_CONNECT_TIMEOUT=5s

# ── Auth / JWT ───────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# ── Cookies ──────────────────────────────────────────────────
COOKIE_SECURE=true             # must be true in production (HTTPS)
COOKIE_DOMAIN=.CHANGE_ME.com   # e.g. .yourdomain.com (leading dot for subdomains)

# ── Seed User (created once on first boot; ignored if user already exists) ──
SEED_USER_ENABLED=true
SEED_USER_FIRST_NAME=Admin
SEED_USER_LAST_NAME=User
SEED_USER_EMAIL=CHANGE_ME@yourdomain.com
SEED_USER_PASSWORD=CHANGE_ME   # must be strong; not "password"
